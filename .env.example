# Copy to `.env` at repo root. Do not commit `.env`.

# --- Supabase (Project Settings → API) ---
SUPABASE_URL="https://qsjoatlwicbzrasevulo.supabase.co"

# Anon / publishable key ONLY (sb_publishable_… or legacy anon JWT).
# The API forwards each user’s JWT to PostgREST; RLS must apply (do not use service_role here).
SUPABASE_KEY="sb_publishable_koU_5bdPqKy2rOJWiXP3BQ_om9a1ytT"

# JWT Secret (same page → JWT Settings / legacy “JWT Secret”) — verifies access tokens from the app.
SUPABASE_JWT_SECRET="iU39+LaMChJxpV16N+EUPUUjHmYaNnKMjVZAxs18UQPRh4FV9QL+4b9rr/82ZF0r+vFolZ1cWRKWOTeFdTWX+A=="

# Optional: keep for SQL scripts or admin tools only — not used by the FastAPI app for user traffic.
# SUPABASE_SECRET_KEY=your-sb-secret-key
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-jwt

# --- CORS (Render / production) ---
# Comma-separated origins that may call this API from a browser (no trailing slashes).
# Always includes http://localhost:5173 and http://127.0.0.1:5173 unless you fork the code.
# CORS_ORIGINS=https://your-app.vercel.app

# --- Frontend (Vite; required for login + API auth header) ---
# Same project as above — only keys prefixed VITE_ are exposed to the browser.
VITE_API_BASE_URL=http://127.0.0.1:8000
VITE_SUPABASE_URL="https://qsjoatlwicbzrasevulo.supabase.co"
VITE_SUPABASE_ANON_KEY="sb_publishable_koU_5bdPqKy2rOJWiXP3BQ_om9a1ytT"

# If Vercel builds without inlining VITE_*: set `frontend/public/noexcuses-bootstrap.json`
# field `renderApiOrigin` to your Render API base URL (no trailing slash), then redeploy the frontend.
