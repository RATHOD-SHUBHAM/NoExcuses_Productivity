# Copy to `.env` at repo root. Do not commit `.env`.

# --- Supabase (Project Settings → API) ---
SUPABASE_URL=https://your-project-id.supabase.co

# Publishable (sb_publishable_…) — browser-safe; OK for SUPABASE_KEY as fallback
SUPABASE_KEY=your-publishable-or-anon-key

# REQUIRED for FastAPI writes: use ONE of these elevated keys (bypasses RLS):
# 1) New: Secret key (sb_secret_…) — API Keys tab → Secret
SUPABASE_SECRET_KEY=your-sb-secret-key
# 2) Legacy: service_role JWT (eyJ…) — Legacy API Keys → service_role
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-jwt

# --- CORS (Render / production) ---
# Comma-separated origins that may call this API from a browser (no trailing slashes).
# Always includes http://localhost:5173 and http://127.0.0.1:5173 unless you fork the code.
# CORS_ORIGINS=https://your-app.vercel.app

# --- Frontend (optional; Vite also reads frontend/.env) ---
# Local dev default in code is http://localhost:8000 if unset.
VITE_API_BASE_URL=http://127.0.0.1:8000
